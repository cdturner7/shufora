# Firebase configuration — copy to .env and fill in your project values
# Find these in Firebase Console → Project Settings → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: comma-separated emails that get dev mode access
VITE_DEV_EMAILS=

# Spotify — create an app at developer.spotify.com
# Add redirect URI: http://localhost:5174/auth/spotify/callback (dev)
#                   https://your-domain/auth/spotify/callback (prod)
VITE_SPOTIFY_CLIENT_ID=

# SoundCloud — register at soundcloud.com/you/apps
# Add redirect URI: http://localhost:5174/auth/soundcloud/callback (dev)
#                   https://your-domain/auth/soundcloud/callback (prod)
VITE_SOUNDCLOUD_CLIENT_ID=
